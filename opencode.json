{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "server": {
        "port": 4096
    },
    "mcp": {
        "perplexity": {
            "enabled": true,
            "type": "local",
            "command": ["npx", "-y", "@perplexity-ai/mcp-server"],
            "environment": {
                "PERPLEXITY_API_KEY": "{file:./.secrets/PERPLEXITY_API_KEY}"
            }
        }
    }
}
